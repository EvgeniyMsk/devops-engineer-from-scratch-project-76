---
profile: min

exclude_paths:
  - roles/geerlingguy.docker/
  - roles/geerlingguy.pip/
  - roles/geerlingguy.nginx/
  - roles/geerlingguy.certbot/
  - roles/datadog.datadog/
  - roles/prometheus/meta/

skip_list:
  - name[missing]
  - var-naming[no-role-prefix]
  - no-changed-when
  - partial-become[task]
  - yaml[line-length]